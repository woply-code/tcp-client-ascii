QWidget#centralwidget {
    background: transparent;
}
QFrame#headerFrame, QFrame#contentFrame {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(122, 146, 184, 0.18);
    border-radius: 18px;
}
QFrame#statusDot {
    background-color: #93a4b7;
    border-radius: 7px;
}
QLabel#titleLabel {
    color: #173a2e;
    font-size: 24px;
    font-weight: 700;
}
QLabel#subtitleLabel {
    color: #60738a;
    font-size: 13px;
}
QGroupBox {
    border: 1px solid #d9e4f0;
    border-radius: 14px;
    margin-top: 14px;
    padding-top: 14px;
    background-color: #fbfefd;
    font-weight: 700;
    color: #264d3a;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 14px;
    padding: 0 6px;
}
QLabel {
    color: #35506f;
    font-size: 13px;
}
QLineEdit, QLabel#hostValueLabel {
    min-height: 38px;
    border: 1px solid #c9d8e8;
    border-radius: 10px;
    background: white;
    padding: 0 12px;
    color: #183153;
}
QLineEdit:focus {
    border: 1px solid #5b8def;
    background: #fdfefe;
}
QPushButton {
    min-height: 40px;
    border-radius: 12px;
    border: none;
    padding: 0 18px;
    font-size: 13px;
    font-weight: 700;
}
QPushButton#listenButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #1f9c57, stop:1 #4fc27d);
    color: white;
}
QPushButton#listenButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #1a8b4d, stop:1 #42ae6f);
}
QPushButton#openButton {
    background-color: #e8f6ee;
    color: #1f7a46;
    border: 1px solid #b8e1c7;
}
QPushButton#openButton:hover {
    background-color: #dcf1e4;
}
QPushButton#closeButton {
    background-color: #fff1ef;
    color: #c05543;
    border: 1px solid #f0c4bd;
}
QPushButton#closeButton:hover {
    background-color: #ffe8e2;
}
QPushButton#backButton {
    min-width: 28px;
    max-width: 28px;
    min-height: 28px;
    max-height: 28px;
    padding: 0;
    font-size: 18px;
    font-weight: 700;
    background-color: #eef3f8;
    color: #405469;
    border: 1px solid #d2dde8;
    border-radius: 14px;
}
QPushButton#backButton:hover {
    background-color: #e4ebf3;
}
QPushButton:pressed {
    padding-top: 1px;
}
QLabel#statusLabel {
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid #d6e0ea;
    background-color: #f7f9fc;
    color: #4d6076;
}
QLabel#statusLabel[state=&quot;idle&quot;] {
    background-color: #f3f6fa;
    border: 1px solid #d8e1eb;
    color: #64778c;
}
QLabel#statusLabel[state=&quot;busy&quot;] {
    background-color: #eefaf4;
    border: 1px solid #c4ead3;
    color: #247149;
}
QLabel#statusLabel[state=&quot;success&quot;] {
    background-color: #eaf8f0;
    border: 1px solid #bde4cb;
    color: #22814d;
}
QLabel#statusLabel[state=&quot;error&quot;] {
    background-color: #fff1ef;
    border: 1px solid #f1c4bc;
    color: #bf5544;
}</string>
