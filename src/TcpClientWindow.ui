}
QLineEdit:focus {
    border: 1px solid #5b8def;
    background: #fdfefe;
}
QComboBox {
    min-height: 38px;
    border: 1px solid #c9d8e8;
    border-radius: 10px;
    background: white;
    padding: 0 12px;
    color: #183153;
}
QComboBox:focus {
    border: 1px solid #5b8def;
}
QComboBox::drop-down {
    border: none;
    width: 28px;
}
QTabWidget::pane {
    border: 1px solid #d9e4f0;
    border-radius: 14px;
    top: -1px;
    background: #ffffff;
}
QTabBar::tab {
    min-height: 38px;
    min-width: 120px;
    padding: 0 18px;
    margin-right: 8px;
    border: 1px solid #d1dceb;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    background: #eef3f9;
    color: #54708f;
    font-weight: 700;
}
QTabBar::tab:selected {
    background: #ffffff;
    color: #225fc1;
    border-color: #bfd3f9;
}
QTabBar::tab:hover:!selected {
    background: #e5edf7;
}
QPushButton {
    min-height: 40px;
    border-radius: 12px;
    border: none;
    padding: 0 18px;
    font-size: 13px;
    font-weight: 700;
}
QPushButton#connectButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #3d7cff, stop:1 #67a4ff);
    color: white;
}
QPushButton#connectButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #2f70f0, stop:1 #5b98f0);
}
QPushButton#sendButton {
    background-color: #eff5ff;
    color: #225fc1;
    border: 1px solid #bfd3f9;
}
QPushButton#sendButton:hover {
    background-color: #e3eeff;
}
QPushButton#openButton {
    background-color: #e8f6ee;
    color: #1f7a46;
    border: 1px solid #b8e1c7;
}
QPushButton#openButton:hover {
    background-color: #dcf1e4;
}
QPushButton#closeButton {
    background-color: #fff1ef;
    color: #c05543;
    border: 1px solid #f0c4bd;
}
QPushButton#closeButton:hover {
    background-color: #ffe8e2;
}
QPushButton#backButton {
    min-width: 28px;
    max-width: 28px;
    min-height: 28px;
    max-height: 28px;
    padding: 0;
    font-size: 18px;
    font-weight: 700;
    background-color: #eef3f8;
    color: #405469;
    border: 1px solid #d2dde8;
    border-radius: 14px;
}
QPushButton#backButton:hover {
    background-color: #e4ebf3;
}
QPushButton:pressed {
    padding-top: 1px;
}
QLabel#statusLabel {
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid #d6e0ea;
    background-color: #f7f9fc;
    color: #4d6076;
}
QLabel#statusLabel[state=&quot;idle&quot;] {
    background-color: #f3f6fa;
    border: 1px solid #d8e1eb;
    color: #64778c;
}
QLabel#statusLabel[state=&quot;busy&quot;] {
    background-color: #eef5ff;
    border: 1px solid #bfd5ff;
    color: #2c63c7;
}
QLabel#statusLabel[state=&quot;success&quot;] {
    background-color: #eaf8f0;
    border: 1px solid #bde4cb;
    color: #22814d;
}
QLabel#statusLabel[state=&quot;error&quot;] {
    background-color: #fff1ef;
    border: 1px solid #f1c4bc;
    color: #bf5544;
}</string>
